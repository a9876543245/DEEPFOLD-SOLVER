# Build artifacts (regenerable)
node_modules/
dist/
dist-ssr/
core/build/
core/build_cpu/
src-tauri/target/
src-tauri/binaries/
release/

# Logs
*.log
logs/

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store

# Local env (never commit secrets — use DEEPFOLD_GOOGLE_CLIENT_SECRET env at build time)
.env
.env.*
!.env.example

# Claude Code session state (per-developer)
.claude/
CLAUDE.md

# gto_output/ structure:
#   cash/          — GTO preflop charts (852 JSON files, ~3.7 MB) consumed by
#                    GameContextSelector + GtoChartBrowser + useGtoAutoRange.
#                    Committed to repo + bundled into installer (v1.8.5+).
#   presolved/     — pre-solved spot bundles (.json.gz) SHIPPED IN INSTALLER;
#                    committed to repo, used by SpotLibrary instant-load.
#   presolved/raw/ — raw bulk-presolve output, regenerable from
#                    scripts/bulk-presolve.mjs (~10 hr on a 5090) — not committed.
#   progress_hybrid.json — bulk-presolve scratch file, not committed.
/gto_output/*
!/gto_output/cash/
!/gto_output/presolved/
/gto_output/presolved/raw/

/src-tauri/gen/
